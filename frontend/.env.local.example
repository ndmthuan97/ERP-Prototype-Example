# ============================================================
# FE env — copy thành .env.local
# ============================================================
# FE chỉ biết DUY NHẤT một URL: API Gateway. Gateway verify JWT rồi route
# tới đúng backend service (/api/auth/*, /api/customers/*, /api/orders/*, ...).
#
# LƯU Ý: biến NEXT_PUBLIC_* được inline vào bundle lúc `next build`, KHÔNG đọc
# lại lúc runtime. Trên Cloud Run phải truyền qua --build-arg NEXT_PUBLIC_API_GATEWAY.
NEXT_PUBLIC_API_GATEWAY=http://localhost:3010
