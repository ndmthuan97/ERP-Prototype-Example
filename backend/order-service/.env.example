# =============================================================================
# Order Service — Environment Variables
# =============================================================================

# Port
PORT=3002

# Database (Postgres)
DATABASE_URL=postgresql://erp_user:erp_password@localhost:5432/erp_dev

# Pub/Sub (dev: emulator, prod: remove PUBSUB_EMULATOR_HOST)
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=erp-prototype

# Upstash Redis (idempotency consumer dedup)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Customer Service URL (for credit-check HTTP call)
CUSTOMER_SERVICE_URL=http://localhost:3001

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
