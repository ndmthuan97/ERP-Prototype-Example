// =============================================================================
// PRISMA SCHEMA — Customer Service
// =============================================================================
// Prisma v7: url/directUrl đã chuyển sang prisma.config.ts
// Schema này chỉ khai báo provider, models, và schemas.
//
// Customer Service sở hữu schema "customer" với 2 bảng:
//   1. cores     — Lưu thông tin khách hàng (aggregate root)
//   2. outbox    — Outbox Pattern để đảm bảo event được gửi đi đáng tin cậy

datasource db {
  // PostgreSQL driver — kết nối Supabase
  provider  = "postgresql"

  // Danh sách schema mà service này quản lý
  // Mỗi service chỉ quản lý schema của riêng mình
  schemas   = ["customer"]
}

generator client {
  // Prisma Client JS mặc định
  provider        = "prisma-client-js"

  // Bật multiSchema để hỗ trợ nhiều schema trên 1 database
  previewFeatures = ["multiSchema"]
}

// =============================================================================
// MODEL: CustomerCore — Aggregate Root của bounded context "Customer"
// =============================================================================
// Bảng này lưu toàn bộ thông tin cốt lõi của khách hàng.
// Áp dụng soft delete thông qua trường deletedAt (không xóa vật lý).
// creditLimitAmount và creditUsedAmount dùng để kiểm tra tín dụng (credit check)
// trước khi cho phép đặt hàng.
model CustomerCore {
  // ID dạng UUID — sinh ở APPLICATION layer (uuidv4 trong command).
  // @default(uuid()) chỉ là fallback nếu app không cung cấp id.
  id                  String    @id @default(uuid())

  // Tên doanh nghiệp / tên khách hàng — trường bắt buộc
  businessName        String    @map("business_name")

  // Mã số thuế — tùy chọn, dùng để định danh pháp lý.
  // @unique: mỗi pháp nhân có 1 MST duy nhất (NULL được phép trùng — KH cá nhân).
  // Chống tạo trùng MST ngay ở tầng DB (không chỉ dựa vào check ở application).
  taxCode             String?   @unique(map: "cores_tax_code_key") @map("tax_code")

  // Trạng thái khách hàng: prospect | active | suspended | archived
  // Mặc định "active" khi tạo mới
  status              String    @default("active")

  // Hạn mức tín dụng tối đa (VND) — nullable vì không phải KH nào cũng có
  // Decimal(15,2) cho phép lưu tới 999,999,999,999,999.99
  creditLimitAmount   Decimal?  @map("credit_limit_amount") @db.Decimal(15, 2)

  // Số tín dụng đã sử dụng — mặc định 0 khi tạo mới
  creditUsedAmount    Decimal   @default(0) @map("credit_used_amount") @db.Decimal(15, 2)

  // Thông tin liên hệ — tất cả đều tùy chọn
  contactName         String?   @map("contact_name")
  contactPhone        String?   @map("contact_phone")
  contactEmail        String?   @map("contact_email")

  // Timestamps — createdAt tự động set khi INSERT, updatedAt tự động cập nhật
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Soft delete: nếu deletedAt != null → khách hàng đã bị "xóa" (archived)
  deletedAt           DateTime? @map("deleted_at")

  // --- Indexes ---
  // Mọi query đều filter "deleted_at IS NULL" → index tránh seq scan
  @@index([deletedAt], map: "idx_cores_deleted_at")
  // Danh sách mặc định sắp xếp theo created_at DESC
  @@index([createdAt], map: "idx_cores_created_at")
  // Lưu ý: tìm kiếm businessName dùng ILIKE '%q%' (leading wildcard) → btree vô dụng.
  // Index trigram GIN được tạo riêng bằng raw SQL (Prisma schema chưa hỗ trợ
  // pg_trgm/GIN ops). Xem prisma/sql/search-index.sql.

  // Map model name "CustomerCore" sang tên bảng "cores" trong DB
  @@map("cores")
  // Đặt bảng này vào schema "customer"
  @@schema("customer")
}

// =============================================================================
// MODEL: Outbox — Outbox Pattern cho Event-Driven Architecture
// =============================================================================
// Thay vì publish event trực tiếp lên Pub/Sub (có thể thất bại),
// ta ghi event vào bảng outbox trong cùng transaction với business data.
// Một worker riêng sẽ poll bảng này và publish lên Pub/Sub,
// sau đó đánh dấu published_at để biết event đã được gửi thành công.
// Pattern này đảm bảo "at-least-once" delivery.
model Outbox {
  // ID dạng UUID cho mỗi event
  id            String    @id @default(uuid())

  // Loại aggregate phát ra event (vd: "Customer")
  aggregateType String    @map("aggregate_type")

  // ID của aggregate liên quan (vd: customer ID)
  aggregateId   String    @map("aggregate_id")

  // Loại event (vd: "customer.created", "customer.updated")
  eventType     String    @map("event_type")

  // Payload chứa dữ liệu event dạng JSON
  payload       Json

  // Thời điểm event được tạo
  createdAt     DateTime  @default(now()) @map("created_at")

  // NULL = chưa được publish → worker sẽ xử lý
  publishedAt   DateTime? @map("published_at")

  // --- Claim + retry/DLQ (an toàn khi chạy nhiều instance worker) ---
  // Khoá tạm: worker đặt locked_until=now()+30s khi CLAIM; worker khác SKIP.
  // Hết hạn (vd worker crash) → event được claim lại → at-least-once.
  lockedUntil   DateTime? @map("locked_until")
  // Số lần đã thử publish — chuyển dead-letter khi vượt ngưỡng
  attempts      Int       @default(0)
  // Thông báo lỗi lần publish gần nhất (cắt ngắn) — phục vụ debug
  lastError     String?   @map("last_error")
  // != NULL → "poison event" đã ngừng retry (cần can thiệp tay)
  deadLetteredAt DateTime? @map("dead_lettered_at")

  // Index để worker query nhanh các event chưa publish
  @@index([publishedAt], map: "idx_outbox_unpublished")

  @@map("outbox")
  @@schema("customer")
}
