# ============================================================
# ERP Prototype — Backend Environment Configuration
# ============================================================
# Copy file này thành .env và điền giá trị thật:
#   cp .env.example .env
# ============================================================

# --- Supabase PostgreSQL ---
# Lấy từ: Supabase Dashboard → Settings → Database → Connection string → URI
# Lưu ý: dùng port 6543 (connection pooling / PgBouncer) cho runtime
# Prisma migrations cần DIRECT_URL port 5432 (direct, không qua pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# --- Upstash Redis ---
# Lấy từ: Upstash Dashboard → Redis → Details
# Upstash dùng REST API (HTTP) thay vì protocol Redis truyền thống
UPSTASH_REDIS_REST_URL=https://[your-redis-id].upstash.io
UPSTASH_REDIS_REST_TOKEN=[your-token]

# --- GCP Pub/Sub ---
# LOCAL DEV: uncomment line below to use Pub/Sub emulator (docker compose up -d)
# When set, @google-cloud/pubsub SDK auto-connects to emulator
# PUBSUB_EMULATOR_HOST=localhost:8085
#
# PRODUCTION: Do NOT set PUBSUB_EMULATOR_HOST → SDK auto-connects to real Pub/Sub
PUBSUB_PROJECT_ID=erp-prototype

# --- JWT Secret ---
# Dùng cho Auth Service sign/verify JWT token
# Tạo random: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Hardening (tùy chọn) ---
# CORS whitelist cho service (phân tách bằng dấu phẩy). Bỏ trống = cho phép tất cả (dev).
CORS_ORIGINS=http://localhost:3000
# Nếu set, endpoint /metrics yêu cầu header "Authorization: Bearer <token>"
# METRICS_TOKEN=change-me

# --- Service Ports ---
API_GATEWAY_PORT=3010
AUTH_SERVICE_PORT=3004
CUSTOMER_SERVICE_PORT=3001
ORDER_SERVICE_PORT=3002
INVENTORY_SERVICE_PORT=3003

# --- Service URLs ---
# API Gateway dùng các URL này để route requests đến đúng service
AUTH_SERVICE_URL=http://localhost:3004
CUSTOMER_SERVICE_URL=http://localhost:3001
ORDER_SERVICE_URL=http://localhost:3002
INVENTORY_SERVICE_URL=http://localhost:3003
